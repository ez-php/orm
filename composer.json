{
  "name": "ez-php/orm",
  "version": "1.0.0",
  "description": "ORM module for the ez-php framework — Active Record style models with a fluent query builder and schema builder",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["orm", "query-builder", "schema-builder", "active-record", "database", "php", "framework", "ez-php"],
  "homepage": "https://github.com/ez-php/orm",
  "support": {
    "issues": "https://github.com/ez-php/orm/issues",
    "source": "https://github.com/ez-php/orm"
  },
  "require": {
    "php": "^8.5",
    "ez-php/contracts": "^1.0",
    "ez-php/console": "^1.0",
    "ez-php/cache": "^1.0"
  },
  "require-dev": {
    "ez-php/docker": "^1.0",
    "ez-php/testing-application": "^1.0",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Orm\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
